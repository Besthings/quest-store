<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login & Register</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen flex items-center justify-center bg-gradient-to-r from-indigo-500 to-purple-600">

    <div class="w-96 bg-white p-8 rounded-xl shadow-2xl">

        <!-- Toggle Buttons -->
        <div class="flex mb-6">
            <button onclick="showLogin()" id="loginBtn"
                class="w-1/2 py-2 font-semibold border-b-2 border-indigo-600 text-indigo-600">
                Login
            </button>
            <button onclick="showRegister()" id="registerBtn"
                class="w-1/2 py-2 font-semibold text-gray-500">
                Register
            </button>
        </div>

        <!-- Login Form -->
        <form id="loginForm">
            <h2 class="text-2xl font-semibold text-center mb-4">Login</h2>

            <div class="mb-4">
                <label class="block mb-1">Username</label>
                <input type="text" 
                    class="w-full border px-3 py-2 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400"
                    placeholder="Enter Username">
            </div>

            <div class="mb-4">
                <label class="block mb-1">Password</label>
                <input type="password"
                    class="w-full border px-3 py-2 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400"
                    placeholder="Enter Password">
            </div>

            <button 
                class="w-full bg-indigo-600 text-white py-2 rounded-md hover:bg-indigo-700 transition">
                Login
            </button>
        </form>

        <!-- Register Form -->
        <form id="registerForm" class="hidden">
            <h2 class="text-2xl font-semibold text-center mb-4">Register</h2>

            <div class="mb-4">
                <label class="block mb-1">Username</label>
                <input type="text"
                    class="w-full border px-3 py-2 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400"
                    placeholder="Enter Username">
            </div>

            <div class="mb-4">
                <label class="block mb-1">Email</label>
                <input type="email"
                    class="w-full border px-3 py-2 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400"
                    placeholder="Enter Email">
            </div>

            <div class="mb-4">
                <label class="block mb-1">Password</label>
                 <input 
                    type="password"
                    id="regPassword"
                    class="w-full border px-3 py-2 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400"
                    placeholder="Enter Password">

                <div class="text-sm mt-2 space-y-1">
                    <p id="length" class="text-red-500">• At least 8 characters</p>
                    <p id="uppercase" class="text-red-500">• At least 1 uppercase letter</p>
                    <p id="lowercase" class="text-red-500">• At least 1 lowercase letter</p>
                    <p id="number" class="text-red-500">• At least 1 number</p>
                </div>
            </div>

            <button 
                class="w-full bg-purple-600 text-white py-2 rounded-md hover:bg-purple-700 transition">
                Register
            </button>
        </form>

    </div>

<script>
    function showLogin() {
        document.getElementById("loginForm").classList.remove("hidden");
        document.getElementById("registerForm").classList.add("hidden");

        document.getElementById("loginBtn").classList.add("border-indigo-600","text-indigo-600");
        document.getElementById("registerBtn").classList.remove("border-indigo-600","text-indigo-600");
    }

    function showRegister() {
        document.getElementById("registerForm").classList.remove("hidden");
        document.getElementById("loginForm").classList.add("hidden");

        document.getElementById("registerBtn").classList.add("border-indigo-600","text-indigo-600");
        document.getElementById("loginBtn").classList.remove("border-indigo-600","text-indigo-600");
    }
</script>

</body>
</html>