<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login & Register</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="/js/theme.js"></script>
    <script>
      tailwind.config = { darkMode: 'class' }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        @keyframes slide {
            0% { transform: translateX(0); }
            100% { transform: translateX(-400vw); }
        }
        
        .animate-slide-desktop {
            animation: slide 40s linear infinite;
        }
        
        @media (max-width: 768px) {
            .animate-slide-desktop {
                animation: slide 20s linear infinite;
            }
        }
    </style>
</head>

<body class="relative min-h-screen flex items-center justify-center overflow-hidden dark:bg-gray-900">

    <!-- Background Slider -->
    <div class="absolute top-0 left-0 flex w-[800vw] h-screen animate-slide-desktop">

        <!-- ชุดที่ 1 -->
        <img src="/images/re9.jpg" class="w-screen h-screen object-cover" />
        <img src="/images/arcraider.jpg" class="w-screen h-screen object-cover" />
        <img src="/images/red2.jpg" class="w-screen h-screen object-cover" />
        <img src="/images/mine.jpg" class="w-screen h-screen object-cover" />

        <!-- ชุดซ้ำ เพื่อให้ลูปเนียน -->
        <img src="/images/re9.jpg" class="w-screen h-screen object-cover" />
        <img src="/images/arcraider.jpg" class="w-screen h-screen object-cover" />
        <img src="/images/red2.jpg" class="w-screen h-screen object-cover" />
        <img src="/images/mine.jpg" class="w-screen h-screen object-cover" />

    </div>

    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/60"></div>

    <!-- Content -->
    <div class="relative z-10 w-96 bg-white/10 backdrop-blur-md border border-white/20 p-8 rounded-xl shadow-2xl">

        <!-- Toggle Buttons -->
        <div class="flex mb-6">
            <button onclick="showLogin()" id="loginBtn"
                class="w-1/2 py-2 font-semibold border-b-2 border-indigo-600 text-indigo-600 transition-all duration-300 ease">
                Login
            </button>
            <button onclick="showRegister()" id="registerBtn"
                class="w-1/2 py-2 font-semibold border-b-2 text-gray-500 transition-all duration-300 ease"
                style="border-bottom-color: transparent;">
                Register
            </button>
        </div>

        <!-- Login Form -->
        <form id="loginForm">
            <h2 class="text-2xl font-semibold text-center mb-4 text-white">Login</h2>

            <div class="mb-4">
                <label class="block mb-1 text-white">Email</label>
                <input type="email" name="email"
                    class="w-full border px-3 py-2 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400"
                    placeholder="Enter Email">
            </div>

            <div class="mb-4">
                <label class="block mb-1 text-white">Password</label>
                <div class="relative">
                    <input type="password" id="loginPassword" name="password"
                        class="w-full border px-3 py-2 pr-10 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400"
                        placeholder="Enter Password">
                    <img src="/images/view.png" alt="Toggle Password" onclick="togglePasswordVisibility('loginPassword', this)" class="absolute right-3 top-1/2 transform -translate-y-1/2 w-5 h-5 cursor-pointer hover:opacity-70" style="user-select: none;">
                </div>
            </div>

            <button type="submit"
                class="w-full bg-indigo-600 text-white py-2 rounded-md hover:bg-indigo-700 transition">
                Login
            </button>
        </form>

        <!-- Register Form -->
        <form id="registerForm" class="hidden">
            <h2 class="text-2xl font-semibold text-center mb-4 text-white">Register</h2>

            <div class="mb-4">
                <label class="block mb-1 text-white">Username</label>
                <input type="text" name="username"
                    class="w-full border px-3 py-2 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400"
                    placeholder="Enter Username">
            </div>

            <div class="mb-4">
                <label class="block mb-1 text-white">Email</label>
                <input type="email" name="email"
                    class="w-full border px-3 py-2 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400"
                    placeholder="Enter Email">
            </div>

            <div class="mb-4">
                <label class="block mb-1 text-white">Password</label>
                <div class="relative">
                    <input 
                        type="password"
                        id="regPassword"
                        name="password"
                        class="w-full border px-3 py-2 pr-10 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400"
                        placeholder="Enter Password">
                    <img src="/images/view.png" alt="Toggle Password" onclick="togglePasswordVisibility('regPassword', this)" class="absolute right-3 top-1/2 transform -translate-y-1/2 w-5 h-5 cursor-pointer hover:opacity-70" style="user-select: none;">
                </div>

                <div class="text-sm mt-2 space-y-1">
                    <p id="length" class="text-red-500 hidden">• At least 8 characters</p>
                    <p id="uppercase" class="text-red-500 hidden">• At least 1 uppercase letter</p>
                    <p id="lowercase" class="text-red-500 hidden">• At least 1 lowercase letter</p>
                    <p id="number" class="text-red-500 hidden">• At least 1 number</p>
                </div>
            </div>

            <button 
                type="submit"
                id="registerBtnSubmit"
                disabled
                class="w-full bg-indigo-600 text-white py-2 rounded-md hover:bg-indigo-700 transition cursor-not-allowed">
                Register
            </button>
        </form>

    </div>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/api/authApi.js"></script>
<script src="/js/login.js"></script>

</body>
</html>