<!-- ─── Header / Navbar ─────────────────────────────────────────────────── -->
<header class="sticky top-0 z-50 border-b border-blue-900/30 bg-header backdrop-blur-md">
  <div class="container mx-auto px-4 h-16 flex items-center gap-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0 group">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center shadow-lg shadow-blue-500/30 group-hover:shadow-blue-400/50 transition-shadow">
        <i data-lucide="gamepad-2" class="w-4 h-4 text-white"></i>
      </div>
      <span class="text-lg font-black tracking-tight bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent hidden sm:block">
        QUEST STORE
      </span>
    </a>

    <!-- Search (desktop) -->
    <form action="/" method="GET" class="flex-1 max-w-xl mx-auto hidden md:flex">
      <div class="relative w-full">
        <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400"></i>
        <input type="text" name="q" placeholder="Search games..."
          class="w-full pl-10 pr-4 py-2 rounded-xl bg-white/5 border border-white/10 text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-blue-500 focus:bg-white/8 transition-all" />
      </div>
    </form>

    <!-- Actions -->
    <div class="flex items-center gap-2 ml-auto md:ml-0">

      <!-- Browse Dropdown -->
      <div class="relative hidden md:block" id="browse-dropdown">
        <button onclick="toggleDropdown('browse-menu')" type="button"
          class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium text-gray-300 hover:text-white hover:bg-white/5 transition-colors">
          Browse
          <i data-lucide="chevron-down" class="h-4 w-4 transition-transform"></i>
        </button>
        <div id="browse-menu" class="hidden absolute top-full mt-2 left-0 w-56 rounded-xl bg-modal border border-blue-900/40 shadow-2xl shadow-black/50 overflow-hidden py-1 z-50">
          <a href="/" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-300 hover:bg-blue-600/10 hover:text-blue-300 transition-colors">
            <i data-lucide="gamepad-2" class="h-4 w-4"></i> All Games
          </a>
          <div class="h-px bg-blue-900/30 my-1"></div>
          <p class="px-4 py-1.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Categories</p>
          <div id="header-categories-desktop">
            <div class="px-4 py-2 text-xs text-gray-500 animate-pulse">Loading...</div>
          </div>
        </div>
      </div>

      <!-- Theme Toggle -->
      <button onclick="toggleTheme()" class="p-2 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-colors" title="Toggle theme">
        <i data-lucide="sun" class="h-5 w-5 hidden dark:block"></i>
        <i data-lucide="moon" class="h-5 w-5 block dark:hidden"></i>
      </button>

      <!-- Cart -->
      <button onclick="toggleCartDrawer()" class="relative p-2 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-colors">
        <i data-lucide="shopping-cart" class="h-5 w-5"></i>
        <% if (cartCount > 0) { %>
          <span data-cart-badge class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-blue-500 text-[10px] font-bold flex items-center justify-center shadow-lg shadow-blue-500/50" style="color:white">
            <%= cartCount %>
          </span>
        <% } %>
      </button>

      <!-- Profile / Login -->
      <% if (currentUser) { %>
        <div class="relative" id="profile-dropdown">
          <button onclick="toggleDropdown('profile-menu')" type="button"
            class="flex items-center gap-2 pl-1 pr-2 py-1 rounded-xl hover:bg-white/5 transition-colors">
            <img src="<%= currentUser.avatar || '' %>" alt="<%= currentUser.username %>"
              class="w-8 h-8 rounded-full border border-blue-500/50 bg-gray-800"
              onerror="this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(currentUser.username) %>&background=1d4ed8&color=fff'" />
            <span class="hidden lg:block text-sm font-medium text-gray-200 max-w-[100px] truncate">
              <%= currentUser.username %>
            </span>
            <i data-lucide="chevron-down" class="hidden lg:block h-3.5 w-3.5 text-gray-400"></i>
          </button>
          <div id="profile-menu" class="hidden absolute top-full mt-2 right-0 w-52 rounded-xl bg-modal border border-blue-900/40 shadow-2xl shadow-black/50 overflow-hidden py-1 z-50">
            <div class="px-4 py-3 border-b border-blue-900/30">
              <p class="text-sm font-semibold text-white truncate"><%= currentUser.username %></p>
              <p class="text-xs text-gray-400 truncate"><%= currentUser.email %></p>
            </div>
            <% if (currentUser.role === 'admin') { %>
              <a href="/admin" class="flex items-center gap-3 px-4 py-2.5 text-sm text-yellow-400 hover:bg-yellow-500/10 transition-colors">
                <i data-lucide="layout-dashboard" class="h-4 w-4"></i> Admin Dashboard
              </a>
            <% } %>
            <a href="/profile" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-300 hover:bg-blue-600/10 hover:text-blue-300 transition-colors">
              <i data-lucide="user" class="h-4 w-4"></i> My Profile
            </a>
            <a href="/profile?tab=keys" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-300 hover:bg-blue-600/10 hover:text-blue-300 transition-colors">
              <i data-lucide="gamepad-2" class="h-4 w-4"></i> Purchased Keys
            </a>
            <a href="/profile?tab=history" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-300 hover:bg-blue-600/10 hover:text-blue-300 transition-colors">
              <i data-lucide="history" class="h-4 w-4"></i> Purchase History
            </a>
            <a href="/profile?tab=favorites" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-300 hover:bg-red-600/10 hover:text-red-300 transition-colors">
              <i data-lucide="heart" class="h-4 w-4"></i> My Favorites
            </a>
            <div class="h-px bg-blue-900/30 my-1"></div>
            <button onclick="handleLogout()" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-red-400 hover:bg-red-500/10 transition-colors text-left">
              <i data-lucide="log-out" class="h-4 w-4"></i> Logout
            </button>
          </div>
        </div>
      <% } else { %>
        <a href="/login"
          class="bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold px-4 py-2 rounded-lg shadow-lg shadow-blue-600/20 transition-all">
          Login
        </a>
      <% } %>

      <!-- Mobile Menu Toggle -->
      <button onclick="toggleMobileMenu()" class="md:hidden p-2 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-colors">
        <i data-lucide="menu" class="h-5 w-5" id="mobile-menu-icon"></i>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Panel -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-blue-900/30 bg-header px-4 pb-4 space-y-3">
    <form action="/" method="GET" class="relative mt-3">
      <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400"></i>
      <input type="text" name="q" placeholder="Search games..."
        class="w-full pl-10 pr-4 py-2 rounded-xl bg-white/5 border border-white/10 text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-blue-500 transition-all" />
    </form>
    <div class="space-y-1 pt-1">
      <a href="/" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-300 hover:bg-white/5 hover:text-white">
        <i data-lucide="gamepad-2" class="h-4 w-4 text-blue-400"></i> All Games
      </a>
      <p class="px-3 pt-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Categories</p>
      <div id="header-categories-mobile">
        <div class="px-3 py-2 text-xs text-gray-500 animate-pulse">Loading...</div>
      </div>
    </div>
  </div>
</header>
