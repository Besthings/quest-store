<div id="admin-games-loading" class="min-h-[60vh] flex items-center justify-center">
  <div class="text-center space-y-4">
    <i data-lucide="loader-2" class="h-12 w-12 text-blue-500 animate-spin mx-auto"></i>
    <p class="text-gray-400 animate-pulse">Loading games management...</p>
  </div>
</div>

<div id="admin-games-content" class="space-y-6 hidden">
  <!-- Header -->
  <div class="flex flex-col md:flex-row justify-between gap-4">
    <h1 class="text-2xl font-bold text-white flex items-center gap-3">
      <i data-lucide="key" class="h-6 w-6 text-blue-400"></i> Manage Games
    </h1>
    <button onclick="openGameDialog()" class="flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white px-4 py-2.5 rounded-xl font-bold transition-colors">
      <i data-lucide="plus" class="h-4 w-4"></i> Add New Game
    </button>
  </div>

  <!-- Search & Filter -->
  <div class="flex flex-col sm:flex-row gap-3">
    <div class="flex items-center gap-2 flex-1 bg-white/5 border border-white/[0.08] rounded-xl px-3 py-2">
      <i data-lucide="search" class="h-4 w-4 text-gray-500 shrink-0"></i>
      <input id="game-search" placeholder="Search games..." oninput="filterGames()"
             class="bg-transparent border-none text-white text-sm placeholder:text-gray-500 focus:outline-none w-full" style="background:transparent !important" />
    </div>
    <div class="flex items-center gap-2">
      <i data-lucide="filter" class="h-4 w-4 text-gray-400"></i>
      <select id="game-cat-filter" onchange="filterGames()"
              class="bg-white/5 border border-white/[0.08] rounded-xl px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500 appearance-none">
        <option value="all">All Categories</option>
        <!-- Categories injected here -->
      </select>
    </div>
  </div>

  <!-- Games Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4" id="games-grid">
    <!-- Games injected here -->
  </div>

  <div id="no-games-found" class="text-center text-gray-500 py-12 bg-white/5 border border-white/[0.08] rounded-2xl hidden">
    No games found
  </div>

  <!-- Pagination -->
  <div class="flex items-center justify-between mt-6" id="games-pagination">
    <p class="text-xs text-gray-500" id="games-page-info"></p>
    <div class="flex items-center gap-1" id="games-page-buttons"></div>
  </div>
</div>

<!-- Game Add/Edit Modal -->
<div id="game-modal" class="fixed inset-0 z-50 hidden">
  <div class="fixed inset-0 bg-black/60" onclick="closeGameDialog()"></div>
  <div class="fixed inset-0 flex items-center justify-center p-4 overflow-y-auto">
    <div class="bg-modal border border-blue-900/40 rounded-2xl p-6 max-w-2xl w-full relative space-y-4 my-8">
      <h3 class="text-white font-bold text-lg" id="game-dialog-title">Add New Game</h3>
      <p class="text-gray-400 text-sm">Fill in game details. Leave keys area blank if no new keys to add.</p>
      <div class="grid gap-4">
        <div><label class="text-gray-300 text-sm block mb-1">Title *</label>
          <input id="gf-title" class="w-full px-3 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-blue-500" placeholder="Game title" /></div>
        <div><label class="text-gray-300 text-sm block mb-1">Description</label>
          <textarea id="gf-desc" class="w-full px-3 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm min-h-[80px] focus:outline-none focus:border-blue-500" placeholder="Game description..."></textarea></div>
        <div><label class="text-gray-300 text-sm block mb-1">Price (฿) *</label>
            <input type="number" id="gf-price" class="w-full px-3 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-blue-500" placeholder="1990" /></div>
        <div><label class="text-gray-300 text-sm block mb-1">Category *</label>
          <select id="gf-category" class="w-full px-3 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-blue-500 appearance-none">
            <option value="">Select category</option>
            <!-- Categories injected here -->
          </select></div>
        <div><label class="text-gray-300 text-sm block mb-1">Cover Image URL</label>
          <input id="gf-cover" class="w-full px-3 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-blue-500" placeholder="https://..." /></div>
        <div><label class="text-gray-300 text-sm block mb-1" id="gf-keys-label">Game Keys (one per line)</label>
          <textarea id="gf-keys" class="w-full px-3 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white font-mono text-xs min-h-[100px] focus:outline-none focus:border-blue-500" placeholder="KEY-XXXX-YYYY-ZZZZ&#10;KEY-AAAA-BBBB-CCCC"></textarea>
          <p class="text-xs text-yellow-500 mt-1 hidden" id="gf-keys-note"></p>
        </div>
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button onclick="closeGameDialog()" class="px-4 py-2 text-gray-400 hover:text-white text-sm transition-colors">Cancel</button>
        <button id="gf-submit" onclick="submitGame()" class="px-6 py-2 bg-blue-600 hover:bg-blue-500 text-white rounded-xl font-bold text-sm transition-colors">Save</button>
      </div>
    </div>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="delete-modal" class="fixed inset-0 z-50 hidden">
  <div class="fixed inset-0 bg-black/60" onclick="closeDeleteModal()"></div>
  <div class="fixed inset-0 flex items-center justify-center p-4">
    <div class="bg-modal border border-red-900/40 rounded-2xl p-6 max-w-md w-full">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-12 h-12 rounded-full bg-red-500/10 border border-red-500/30 flex items-center justify-center flex-shrink-0">
          <i data-lucide="alert-triangle" class="h-6 w-6 text-red-400"></i>
        </div>
        <div>
          <h3 class="text-white font-bold text-lg">Delete Game</h3>
          <p class="text-gray-400 text-sm">This action cannot be undone.</p>
        </div>
      </div>
      <p id="delete-modal-message" class="text-gray-300 text-sm mb-6"></p>
      <div class="flex justify-end gap-3">
        <button onclick="closeDeleteModal()" class="px-4 py-2 text-gray-400 hover:text-white text-sm transition-colors">Cancel</button>
        <button id="delete-modal-confirm" onclick="confirmDeleteGame()" class="px-6 py-2 bg-red-600 hover:bg-red-500 text-white rounded-xl font-bold text-sm transition-colors flex items-center gap-2">
          <i data-lucide="trash-2" class="h-4 w-4"></i> Delete
        </button>
      </div>
    </div>
  </div>
</div>

<!-- View Keys Modal -->
<div id="keys-modal" class="fixed inset-0 z-50 hidden">
  <div class="fixed inset-0 bg-black/60" onclick="closeKeysModal()"></div>
  <div class="fixed inset-0 flex items-center justify-center p-4">
    <div class="bg-modal border border-blue-900/40 rounded-2xl p-6 max-w-2xl w-full max-h-[80vh] flex flex-col relative space-y-4">
      <div class="flex items-center justify-between border-b border-white/10 pb-4">
        <div>
          <h3 class="text-white font-bold text-lg" id="keys-modal-title">Game Keys</h3>
          <p class="text-gray-400 text-xs mt-1" id="keys-modal-subtitle"></p>
        </div>
        <button onclick="closeKeysModal()" class="text-gray-400 hover:text-white transition-colors">
          <i data-lucide="x" class="h-5 w-5"></i>
        </button>
      </div>
      
      <div class="overflow-y-auto pr-2 space-y-2 flex-1" id="keys-list-container">
        <!-- Keys injected here -->
      </div>

      <div class="pt-2 border-t border-white/10 flex justify-end">
        <button onclick="closeKeysModal()" class="px-6 py-2 bg-white/5 hover:bg-white/10 text-white rounded-xl font-bold text-sm transition-colors">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
let allGames = [];
let allCategories = [];
let deleteGameId = null;
let gamesPerPage = 8;
let gamesCurrentPage = 1;
let editingGameId = null;

function renderGames(games) {
  const grid = document.getElementById('games-grid');
  const totalPages = Math.max(1, Math.ceil(games.length / gamesPerPage));
  if (gamesCurrentPage > totalPages) gamesCurrentPage = totalPages;
  
  const start = (gamesCurrentPage - 1) * gamesPerPage;
  const end = start + gamesPerPage;
  const paginated = games.slice(start, end);

  if (games.length === 0) {
    grid.innerHTML = '';
    document.getElementById('no-games-found').classList.remove('hidden');
    document.getElementById('games-pagination').classList.add('hidden');
    return;
  }

  document.getElementById('no-games-found').classList.add('hidden');
  document.getElementById('games-pagination').classList.remove('hidden');

  grid.innerHTML = paginated.map(game => {
    const stock = game.keys ? game.keys.filter(k => !k.is_sold).length : 0;
    const catName = game.category ? game.category.category_name : (allCategories.find(c => c.id == game.category_id)?.category_name || '—');
    
    return `
      <div class="game-card group bg-white/5 border border-white/[0.08] rounded-2xl overflow-hidden hover:border-blue-500/30 transition-all cursor-pointer" 
           onclick="viewKeys('${game.id}')">
        <div class="relative aspect-[16/10] overflow-hidden">
          <img src="${game.image_url || '/images/arcraider.jpg'}" alt="${game.title}"
               class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity"></div>
          
          <!-- View Keys Overlay Hint -->
          <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
            <div class="bg-blue-600/90 text-white px-3 py-1.5 rounded-full text-xs font-bold flex items-center gap-2 shadow-xl">
               <i data-lucide="eye" class="h-3.5 w-3.5"></i> View Keys
            </div>
          </div>

          <div class="absolute bottom-2 right-2">
            <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-md backdrop-blur-sm ${stock > 0 ? 'bg-green-500/20 text-green-400 border border-green-500/30' : 'bg-red-500/20 text-red-400 border border-red-500/30'}">
              ${stock} keys
            </span>
          </div>
        </div>
        <div class="p-4 space-y-2">
          <h3 class="font-semibold text-white text-sm truncate group-hover:text-blue-400 transition-colors">${game.title}</h3>
          <p class="text-gray-500 text-xs">${catName}</p>
          <div class="flex items-center justify-between pt-1">
            <p class="text-white font-bold text-sm">฿${game.price.toLocaleString()}</p>
            <div class="flex gap-1">
              <button onclick='event.stopPropagation(); openGameDialog(${(JSON.stringify({
                id: game.id,
                title: game.title,
                description: game.description,
                price: game.price,
                category_id: game.category_id,
                image_url: game.image_url,
                keyCount: game.keys ? game.keys.length : 0
              }))})' class="p-1.5 rounded-lg text-blue-400 hover:bg-blue-500/10 transition-colors" title="Edit Game">
                <i data-lucide="edit-3" class="h-3.5 w-3.5"></i>
              </button>
              <button onclick="event.stopPropagation(); deleteGameConfirm('${game.id}')" class="p-1.5 rounded-lg text-red-400 hover:bg-red-500/10 transition-colors" title="Delete Game">
                <i data-lucide="trash-2" class="h-3.5 w-3.5"></i>
              </button>
            </div>
          </div>
        </div>
      </div>
    `;
  }).join('');
  
  renderPagination(games.length);
  lucide.createIcons();
}

function renderPagination(totalGames) {
  const info = document.getElementById('games-page-info');
  const btnContainer = document.getElementById('games-page-buttons');
  const totalPages = Math.max(1, Math.ceil(totalGames / gamesPerPage));

  info.textContent = `Page ${gamesCurrentPage} of ${totalPages} (${totalGames} games)`;

  let html = '';
  html += `<button onclick="goGamesPage(${Math.max(1, gamesCurrentPage - 1)})" class="px-2.5 py-1 rounded-lg text-xs ${gamesCurrentPage <= 1 ? 'text-gray-600 cursor-not-allowed' : 'text-gray-400 hover:text-white hover:bg-white/10'}" ${gamesCurrentPage <= 1 ? 'disabled' : ''}>Previous</button>`;

  const startP = Math.max(1, gamesCurrentPage - 2);
  const endP = Math.min(totalPages, startP + 4);
  
  for (let p = startP; p <= endP; p++) {
    if (p === gamesCurrentPage) {
      html += `<button class="px-2.5 py-1 rounded-lg text-xs bg-blue-600 text-white font-bold">${p}</button>`;
    } else {
      html += `<button onclick="goGamesPage(${p})" class="px-2.5 py-1 rounded-lg text-xs text-gray-400 hover:text-white hover:bg-white/10">${p}</button>`;
    }
  }

  html += `<button onclick="goGamesPage(${Math.min(totalPages, gamesCurrentPage + 1)})" class="px-2.5 py-1 rounded-lg text-xs ${gamesCurrentPage >= totalPages ? 'text-gray-600 cursor-not-allowed' : 'text-gray-400 hover:text-white hover:bg-white/10'}" ${gamesCurrentPage >= totalPages ? 'disabled' : ''}>Next</button>`;
  btnContainer.innerHTML = html;
}

function goGamesPage(p) {
  gamesCurrentPage = p;
  filterGames();
}

function filterGames() {
  const q = document.getElementById('game-search').value.toLowerCase();
  const cat = document.getElementById('game-cat-filter').value;
  
  const filtered = allGames.filter(game => {
    const matchTitle = game.title.toLowerCase().includes(q);
    const matchCat = cat === 'all' || game.category_id == cat;
    return matchTitle && matchCat;
  });

  renderGames(filtered);
}

function openGameDialog(game) {
  editingGameId = game ? game.id : null;
  document.getElementById('game-dialog-title').textContent = game ? 'Edit Game' : 'Add New Game';
  document.getElementById('gf-title').value = game ? game.title : '';
  document.getElementById('gf-desc').value = game ? game.description : '';
  document.getElementById('gf-price').value = game ? game.price : '';
  document.getElementById('gf-category').value = game ? game.category_id : '';
  document.getElementById('gf-cover').value = game ? game.image_url : '';
  document.getElementById('gf-keys').value = '';
  
  const note = document.getElementById('gf-keys-note');
  const label = document.getElementById('gf-keys-label');
  if (game) {
    label.textContent = 'Add New Keys (one per line)';
    note.textContent = `Existing ${game.keyCount} key(s) will be preserved. New keys entered here will be added.`;
    note.classList.remove('hidden');
  } else {
    label.textContent = 'Game Keys (one per line)';
    note.classList.add('hidden');
  }
  document.getElementById('game-modal').classList.remove('hidden');
}

function closeGameDialog() { document.getElementById('game-modal').classList.add('hidden'); }

async function submitGame() {
  const data = {
    title: document.getElementById('gf-title').value,
    description: document.getElementById('gf-desc').value,
    price: Number(document.getElementById('gf-price').value),
    category_id: document.getElementById('gf-category').value,
    image_url: document.getElementById('gf-cover').value,
    newKeys: document.getElementById('gf-keys').value.split('\n').filter(k => k.trim()).map(k => k.trim()),
  };

  if (!data.title || !data.price || !data.category_id) {
    Toast.error('Please fill title, price, and category');
    return;
  }

  try {
    if (editingGameId) {
      const res = await axios.put('/api/games/' + editingGameId, data);
      Toast.success('Game updated!');
      // Update local state - API returns { message, game }
      const updatedGame = res.data.game;
      const idx = allGames.findIndex(g => g.id == editingGameId);
      if (idx !== -1) allGames[idx] = { ...allGames[idx], ...updatedGame };
    } else {
      const res = await axios.post('/api/games', data);
      Toast.success('Game added!');
      // API returns { message, game }
      allGames.unshift(res.data.game);
    }
    closeGameDialog();
    filterGames();
  } catch (err) { 
    Toast.error('Failed to save game'); 
    console.error(err);
  }
}

function deleteGameConfirm(id) {
  deleteGameId = id;
  document.getElementById('delete-modal-message').textContent = 'Are you sure you want to delete this game? All associated game keys will also be deleted.';
  document.getElementById('delete-modal').classList.remove('hidden');
  lucide.createIcons();
}

function closeDeleteModal() {
  document.getElementById('delete-modal').classList.add('hidden');
  deleteGameId = null;
}

async function confirmDeleteGame() {
  if (!deleteGameId) return;
  try {
    await axios.delete('/api/games/' + deleteGameId);
    Toast.success('Game deleted!');
    closeDeleteModal();
    // Update local state
    allGames = allGames.filter(g => g.id != deleteGameId);
    filterGames();
  } catch { Toast.error('Failed to delete'); }
}

function viewKeys(gameId) {
  const game = allGames.find(g => g.id == gameId);
  if (!game) return;

  const modal = document.getElementById('keys-modal');
  const title = document.getElementById('keys-modal-title');
  const subtitle = document.getElementById('keys-modal-subtitle');
  const container = document.getElementById('keys-list-container');

  title.textContent = game.title;
  const availableCount = game.keys ? game.keys.filter(k => !k.is_sold).length : 0;
  subtitle.textContent = `${game.keys ? game.keys.length : 0} total keys (${availableCount} available)`;

  if (!game.keys || game.keys.length === 0) {
    container.innerHTML = `
      <div class="py-10 text-center text-gray-500 bg-white/5 rounded-xl border border-dashed border-white/10">
        <i data-lucide="info" class="h-8 w-8 mx-auto mb-2 opacity-20"></i>
        <p class="text-sm">No keys added for this game yet.</p>
      </div>
    `;
  } else {
    container.innerHTML = game.keys.map(key => `
      <div class="flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/10">
        <div class="flex flex-col">
          <span class="text-xs font-mono text-blue-400">${key.secret_key}</span>
          <span class="text-[10px] text-gray-500 mt-1">ID: #${key.id}</span>
        </div>
        <span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${key.is_sold ? 'bg-red-500/10 text-red-400 border border-red-500/20' : 'bg-green-500/10 text-green-400 border border-green-500/20'}">
          ${key.is_sold ? 'SOLD' : 'AVAILABLE'}
        </span>
      </div>
    `).join('');
  }

  modal.classList.remove('hidden');
  lucide.createIcons();
}

function closeKeysModal() {
  document.getElementById('keys-modal').classList.add('hidden');
}

document.addEventListener('DOMContentLoaded', async () => {
  try {
    const [gamesRes, catsRes] = await Promise.all([
      axios.get('/api/games?limit=1000'),
      axios.get('/api/categories?limit=1000')
    ]);

    allGames = gamesRes.data.data ? gamesRes.data.data : gamesRes.data;
    allCategories = catsRes.data.data ? catsRes.data.data : catsRes.data;

    // Populate Filters and Modals
    const filterSelect = document.getElementById('game-cat-filter');
    const gfSelect = document.getElementById('gf-category');
    
    const catOptions = allCategories.map(c => `<option value="${c.id}">${c.category_name}</option>`).join('');
    filterSelect.innerHTML += catOptions;
    gfSelect.innerHTML += catOptions;

    document.getElementById('admin-games-loading').classList.add('hidden');
    document.getElementById('admin-games-content').classList.remove('hidden');

    filterGames();
  } catch (err) {
    console.error('Failed to load games data:', err);
    document.getElementById('admin-games-loading').innerHTML = `
      <div class="text-center text-red-500">
        <p>Failed to load games management data. Please try again.</p>
      </div>
    `;
  }
});
</script>
