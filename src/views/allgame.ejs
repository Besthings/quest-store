<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Store - THE GAME STORE</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-white">

<!-- Navbar -->
<nav class="bg-gray-800 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <h1 class="text-2xl font-bold text-indigo-400">THE GAME STORE</h1>
        <div class="space-x-4">
            <a href="/dashboard" class="hover:text-indigo-400">Dashboard</a>
            <a href="/login" class="bg-red-500 px-4 py-2 rounded hover:bg-red-600">Logout</a>
        </div>
    </div>
</nav>

<div class="max-w-7xl mx-auto px-6 py-10">

    <!-- Search + Filter -->
    <div class="flex flex-col md:flex-row gap-4 justify-between mb-8">

        <!-- Search -->
        <input 
            type="text"
            id="searchInput"
            placeholder="Search games..."
            class="px-4 py-2 rounded text-black w-full md:w-1/3"
            onkeyup="searchGames()"
        >

        <!-- Category Filter -->
        <select id="categoryFilter" onchange="filterCategory()" 
            class="px-4 py-2 rounded text-black w-full md:w-1/4">
            <option value="all">All Categories</option>
            <option value="Action">Action</option>
            <option value="Adventure">Adventure</option>
            <option value="RPG">RPG</option>
        </select>

    </div>

    <!-- Game Grid -->
    <div id="gameGrid" class="grid md:grid-cols-4 gap-6">

        <!-- Card Template -->
        <% const games = [
            { name: "Game Alpha", category: "Action" },
            { name: "Game Bravo", category: "Adventure" },
            { name: "Game Charlie", category: "RPG" },
            { name: "Game Delta", category: "Action" },
            { name: "Game Echo", category: "Adventure" },
            { name: "Game Foxtrot", category: "RPG" },
            { name: "Game Gamma", category: "Action" },
            { name: "Game Hero", category: "Adventure" }
        ]; %>

        <% games.forEach(game => { %>
            <div class="game-card bg-gray-800 rounded-xl overflow-hidden shadow-lg hover:scale-105 transition"
                 data-name="<%= game.name %>"
                 data-category="<%= game.category %>">

                <img src="/images/roll-safe-meme-1.jpg" class="h-40 w-full object-cover">

                <div class="p-4">
                    <h3 class="font-semibold"><%= game.name %></h3>
                    <p class="text-sm text-indigo-400"><%= game.category %></p>
                    <p class="text-indigo-400">$49.99</p>
                </div>
            </div>
        <% }) %>

    </div>

</div>

<script>
function searchGames() {
    let input = document.getElementById("searchInput").value.toLowerCase();
    let cards = document.querySelectorAll(".game-card");

    cards.forEach(card => {
        let name = card.dataset.name.toLowerCase();
        card.style.display = name.includes(input) ? "block" : "none";
    });
}

function filterCategory() {
    let selected = document.getElementById("categoryFilter").value;
    let cards = document.querySelectorAll(".game-card");

    cards.forEach(card => {
        let category = card.dataset.category;
        if(selected === "all" || category === selected) {
            card.style.display = "block";
        } else {
            card.style.display = "none";
        }
    });
}
</script>

</body>
</html>