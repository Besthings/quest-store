<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quest Store</title>
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        @keyframes slide {
            0% { transform: translateX(0); }
            100% { transform: translateX(-400vw); }
        }
    </style>
</head>

<body class="relative h-screen overflow-hidden">

    <!-- Background Slider  -->
    <div class="absolute top-0 left-0 flex w-[800vw] h-screen animate-[slide_20s_linear_infinite]">

        <!-- ชุดที่ 1 -->
        <img src="/images/re9.jpg" class="w-screen h-screen object-cover" />
        <img src="/images/arcraider.jpg" class="w-screen h-screen object-cover" />
        <img src="/images/red2.jpg" class="w-screen h-screen object-cover" />
        <img src="/images/mine.jpg" class="w-screen h-screen object-cover" />

        <!-- ชุดซ้ำ เพื่อให้ลูปเนียน -->
        <img src="/images/re9.jpg" class="w-screen h-screen object-cover" />
        <img src="/images/arcraider.jpg" class="w-screen h-screen object-cover" />
        <img src="/images/red2.jpg" class="w-screen h-screen object-cover" />
        <img src="/images/mine.jpg" class="w-screen h-screen object-cover" />

    </div>

    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/60"></div>

    <!-- กล่องกลางแบบ Glass -->
    <div class="relative z-10 flex items-center justify-center h-full px-4">
        <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-10 text-center text-white shadow-2xl">

            <h1 class="text-5xl md:text-6xl font-bold text-red-500 drop-shadow-lg mb-4">
                Quest Store
            </h1>

            <p class="text-lg md:text-xl text-gray-200 mb-8">
                ที่นี่คือศูนย์รวมทุกเควสต์แห่งความมันส์
            </p>

            <a href="/login">
                <button class="bg-blue-600 hover:bg-blue-700 px-8 py-3 rounded-xl text-lg font-semibold transition duration-300 shadow-xl hover:scale-105">
                    เข้าสู่เว็บไซต์
                </button>
            </a>

        </div>
    </div>

</body>
</html>