<!DOCTYPE html>
<html lang="en" id="html-root">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: { extend: { fontFamily: { sans: ['Noto Sans Thai','Inter','system-ui','sans-serif'] } } }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/theme.css" />
  <script>
    (function() {
      var t = localStorage.getItem('qs-theme');
      if (!t) { t = 'dark'; localStorage.setItem('qs-theme', 'dark'); }
      document.documentElement.className = t;
    })();
  </script>
</head>
<body class="bg-body text-body font-sans transition-colors duration-300 admin-panel">

<div id="admin-shell" class="admin-shell flex h-screen overflow-hidden">
  <!-- Sidebar -->
  <aside id="admin-sidebar" class="hidden md:flex flex-col w-64 bg-sidebar border-r border-white/5 transition-all duration-300 shrink-0 print:hidden hide-on-print">
    <!-- Logo -->
    <div class="flex items-center p-4 border-b border-white/5 gap-3">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center shrink-0 shadow-lg shadow-blue-500/20">
        <i data-lucide="gamepad-2" class="w-4 h-4 text-white"></i>
      </div>
      <div>
        <p class="text-sm font-black text-white">QUEST STORE</p>
        <p class="text-[10px] text-blue-400 font-semibold">Admin Panel</p>
      </div>
    </div>
    <!-- Nav -->
    <nav class="flex-1 p-3 space-y-1 overflow-y-auto">
      <% const navItems = [
        { icon: 'layout-dashboard', label: 'Dashboard', path: '/admin' },
        { icon: 'users', label: 'Users', path: '/admin/users' },
        { icon: 'folder-tree', label: 'Categories', path: '/admin/categories' },
        { icon: 'gamepad-2', label: 'Games', path: '/admin/games' },
        { icon: 'shopping-bag', label: 'Orders', path: '/admin/orders' },
        { icon: 'file-text', label: 'Reports', path: '/admin/reports' },
      ]; %>
      <% navItems.forEach(item => {
        const isActive = item.path === '/admin' ? page === 'admin-dashboard' : page.includes(item.path.split('/').pop());
      %>
        <a href="<%= item.path %>"
          class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all group
            <%= isActive ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">
          <i data-lucide="<%= item.icon %>" class="h-4 w-4 shrink-0 <%= isActive ? 'text-white' : 'text-gray-400 group-hover:text-white' %>"></i>
          <span><%= item.label %></span>
        </a>
      <% }) %>
    </nav>
    <!-- Footer -->
    <div class="p-3 border-t border-white/5 space-y-1">
      <a href="/" class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm text-gray-500 hover:text-white hover:bg-white/5 transition-colors">
        <i data-lucide="home" class="h-4 w-4 shrink-0"></i> <span>Back to Store</span>
      </a>
    </div>
  </aside>

  <!-- Mobile Overlay -->
  <div id="admin-mobile-overlay" class="md:hidden fixed inset-0 z-50 hidden print:hidden hide-on-print">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="document.getElementById('admin-mobile-overlay').classList.add('hidden')"></div>
    <aside class="relative z-10 h-full w-64 bg-sidebar border-r border-white/5 flex flex-col">
      <div class="flex items-center p-4 border-b border-white/5 gap-3">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center shrink-0 shadow-lg shadow-blue-500/20">
          <i data-lucide="gamepad-2" class="w-4 h-4 text-white"></i>
        </div>
        <div><p class="text-sm font-black text-white">QUEST STORE</p><p class="text-[10px] text-blue-400 font-semibold">Admin Panel</p></div>
      </div>
      <nav class="flex-1 p-3 space-y-1 overflow-y-auto">
        <% navItems.forEach(item => {
          const isActive = item.path === '/admin' ? page === 'admin-dashboard' : page.includes(item.path.split('/').pop());
        %>
          <a href="<%= item.path %>" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all group
            <%= isActive ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">
            <i data-lucide="<%= item.icon %>" class="h-4 w-4 shrink-0"></i><span><%= item.label %></span>
          </a>
        <% }) %>
      </nav>
      <div class="p-3 border-t border-white/5">
        <a href="/" class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm text-gray-500 hover:text-white hover:bg-white/5 transition-colors">
          <i data-lucide="home" class="h-4 w-4 shrink-0"></i><span>Back to Store</span>
        </a>
      </div>
    </aside>
  </div>

  <!-- Main Content -->
  <div class="flex-1 flex flex-col overflow-hidden print-main-view">
    <header class="admin-topbar h-14 border-b border-white/5 bg-header backdrop-blur-md px-6 flex items-center justify-between shrink-0 print:hidden hide-on-print">
      <button class="md:hidden text-gray-400 hover:text-white" onclick="document.getElementById('admin-mobile-overlay').classList.remove('hidden')">
        <i data-lucide="menu" class="h-5 w-5"></i>
      </button>
      <div class="hidden md:block">
        <p class="text-sm font-semibold text-body"><%= title.split(' – ')[0] %></p>
      </div>
      <div class="ml-auto flex items-center gap-3">
        <button onclick="toggleTheme()" class="p-1.5 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-colors" title="Toggle theme">
          <i data-lucide="sun" class="h-4 w-4 hidden dark:block"></i>
          <i data-lucide="moon" class="h-4 w-4 block dark:hidden"></i>
        </button>
        <span class="text-xs text-gray-500">Quest Store Admin</span>
        <div class="w-2 h-2 rounded-full bg-green-400"></div>
      </div>
    </header>
    <main class="admin-content flex-1 overflow-y-auto p-6">
      <%- body %>
    </main>
  </div>
</div>

<div id="toast-container" class="fixed top-4 right-4 z-[9999] flex flex-col gap-2 pointer-events-none"></div>
<script src="/js/toast.js"></script>
<script src="/js/app.js"></script>
<script>lucide.createIcons();</script>
</body>
</html>
